{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2026-01-29 19:52:57.389471",
 "custom_format": 1,
 "default_print_language": "en-GB",
 "disabled": 0,
 "doc_type": "Service Instance",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap');\r\n        \r\n        @media print {\r\n            @page {\r\n                margin: 15mm 10mm 15mm 10mm;\r\n                size: A4 portrait;\r\n            }\r\n            \r\n            body { \r\n                margin: 0;\r\n                padding: 0;\r\n                -webkit-print-color-adjust: exact;\r\n            }\r\n            \r\n            .no-print { display: none !important; }\r\n            .page-break { page-break-after: always; break-after: page; }\r\n        }\r\n        \r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        body {\r\n            font-family: 'Inter', sans-serif;\r\n            background: white;\r\n            color: #1e293b;\r\n            line-height: 1.5;\r\n            font-size: 13px;\r\n        }\r\n\r\n        .report-container {\r\n            width: 100%;\r\n            max-width: 794px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        /* Header - Blue Theme with Smaller Badge */\r\n        .header-section {\r\n            text-align: center;\r\n            margin-bottom: 20px;\r\n            padding-bottom: 20px;\r\n            border-bottom: 3px solid #2563eb;\r\n            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);\r\n            padding: 25px 30px;\r\n            border-radius: 10px 10px 0 0;\r\n            color: white;\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .header-section::before {\r\n            content: '';\r\n            position: absolute;\r\n            top: -30%;\r\n            right: -10%;\r\n            width: 200px;\r\n            height: 200px;\r\n            background: rgba(255, 255, 255, 0.1);\r\n            border-radius: 50%;\r\n            z-index: 1;\r\n        }\r\n\r\n        .service-icon {\r\n            width: 50px;\r\n            height: 50px;\r\n            background: rgba(255, 255, 255, 0.2);\r\n            border-radius: 50%;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            margin: 0 auto 12px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .service-icon svg {\r\n            width: 25px;\r\n            height: 25px;\r\n            fill: white;\r\n        }\r\n\r\n        .report-title {\r\n            font-family: 'Playfair Display', serif;\r\n            font-size: 26px;\r\n            font-weight: 600;\r\n            margin: 0 0 8px 0;\r\n            letter-spacing: -0.5px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .report-subtitle {\r\n            font-size: 15px;\r\n            opacity: 0.9;\r\n            font-weight: 400;\r\n            margin-bottom: 8px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        /* Smaller Service Badge */\r\n        .service-badge {\r\n            display: inline-block;\r\n            background: rgba(255, 255, 255, 0.2);\r\n            color: white;\r\n            padding: 6px 15px;\r\n            border-radius: 40px;\r\n            font-size: 12px;\r\n            font-weight: 600;\r\n            margin-top: 8px;\r\n            backdrop-filter: blur(8px);\r\n            position: relative;\r\n            z-index: 2;\r\n            border: 1px solid rgba(255, 255, 255, 0.3);\r\n        }\r\n\r\n        /* Service Information */\r\n        .service-info {\r\n            margin-bottom: 20px;\r\n        }\r\n\r\n        .info-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 12px;\r\n            margin-bottom: 15px;\r\n        }\r\n\r\n        .info-card {\r\n            background: white;\r\n            padding: 18px;\r\n            border-radius: 8px;\r\n            border: 1px solid #e2e8f0;\r\n            border-top: 4px solid #3b82f6;\r\n            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.04);\r\n        }\r\n\r\n        .info-label {\r\n            font-size: 10px;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.9px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .info-value {\r\n            font-size: 15px;\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .info-highlight {\r\n            color: #2563eb;\r\n            font-weight: 700;\r\n        }\r\n\r\n        /* Status Badges */\r\n        .status-badge {\r\n            display: inline-block;\r\n            padding: 5px 10px;\r\n            border-radius: 5px;\r\n            font-size: 10px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.4px;\r\n        }\r\n\r\n        .status-scheduled {\r\n            background: #dbeafe;\r\n            color: #1e40af;\r\n        }\r\n\r\n        .status-ongoing {\r\n            background: #fef3c7;\r\n            color: #92400e;\r\n        }\r\n\r\n        .status-completed {\r\n            background: #dcfce7;\r\n            color: #166534;\r\n        }\r\n\r\n        .status-cancelled {\r\n            background: #fee2e2;\r\n            color: #991b1b;\r\n        }\r\n\r\n        /* Section Titles */\r\n        .section-title {\r\n            font-family: 'Playfair Display', serif;\r\n            font-size: 18px;\r\n            color: #1e40af;\r\n            margin: 20px 0 15px 0;\r\n            padding-bottom: 8px;\r\n            border-bottom: 2px solid #3b82f6;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 8px;\r\n        }\r\n\r\n        /* Service Details Section */\r\n        .details-section {\r\n            background: #f0f9ff;\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #bae6fd;\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .details-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 12px;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .detail-card {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #dbeafe;\r\n            text-align: center;\r\n        }\r\n\r\n        .detail-label {\r\n            font-size: 10px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.7px;\r\n        }\r\n\r\n        .detail-value {\r\n            font-size: 16px;\r\n            font-weight: 700;\r\n            color: #1e40af;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Leadership Section */\r\n        .leadership-section {\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .leadership-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 12px;\r\n            margin-top: 12px;\r\n        }\r\n\r\n        .leadership-card {\r\n            background: white;\r\n            padding: 16px;\r\n            border-radius: 8px;\r\n            border: 1px solid #e2e8f0;\r\n            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.03);\r\n            text-align: center;\r\n        }\r\n\r\n        .leadership-role {\r\n            font-size: 11px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .leadership-name {\r\n            font-size: 15px;\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n        }\r\n\r\n        /* Attendance Section */\r\n        .attendance-section {\r\n            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #bae6fd;\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .attendance-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(5, 1fr);\r\n            gap: 10px;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .attendance-card {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #dbeafe;\r\n            text-align: center;\r\n        }\r\n\r\n        .attendance-label {\r\n            font-size: 10px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.7px;\r\n        }\r\n\r\n        .attendance-value {\r\n            font-size: 18px;\r\n            font-weight: 700;\r\n            color: #1e40af;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        .total-attendance {\r\n            grid-column: span 5;\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n            color: white;\r\n            padding: 18px;\r\n            border: none;\r\n        }\r\n\r\n        .total-attendance .attendance-label {\r\n            color: rgba(255, 255, 255, 0.9);\r\n        }\r\n\r\n        .total-attendance .attendance-value {\r\n            color: white;\r\n            font-size: 24px;\r\n        }\r\n\r\n        /* Collections Section */\r\n        .collections-section {\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .collections-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(4, 1fr);\r\n            gap: 10px;\r\n            margin-top: 12px;\r\n        }\r\n\r\n        .collection-card {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #e2e8f0;\r\n            text-align: center;\r\n            border-top: 3px solid #3b82f6;\r\n        }\r\n\r\n        .collection-label {\r\n            font-size: 10px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.7px;\r\n        }\r\n\r\n        .collection-value {\r\n            font-size: 16px;\r\n            font-weight: 700;\r\n            color: #059669;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Sermon Section */\r\n        .sermon-section {\r\n            background: #f8fafc;\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #e2e8f0;\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .sermon-header {\r\n            display: grid;\r\n            grid-template-columns: 2fr 1fr;\r\n            gap: 15px;\r\n            margin-bottom: 15px;\r\n        }\r\n\r\n        .sermon-title {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #e2e8f0;\r\n        }\r\n\r\n        .sermon-publisher {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #e2e8f0;\r\n            text-align: center;\r\n        }\r\n\r\n        /* Ministry Team Table */\r\n        .ministry-section {\r\n            margin: 20px 0;\r\n        }\r\n\r\n        .team-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            margin-top: 12px;\r\n            font-size: 11px;\r\n            table-layout: fixed;\r\n        }\r\n\r\n        .team-table thead {\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n        }\r\n\r\n        .team-table th {\r\n            padding: 12px 10px;\r\n            text-align: left;\r\n            font-weight: 600;\r\n            color: white;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.4px;\r\n            border: none;\r\n            font-size: 10px;\r\n        }\r\n\r\n        .team-table td {\r\n            padding: 10px;\r\n            border-bottom: 1px solid #e2e8f0;\r\n        }\r\n\r\n        .team-table tbody tr:nth-child(even) {\r\n            background-color: #f8fafc;\r\n        }\r\n\r\n        .present-badge {\r\n            display: inline-block;\r\n            width: 20px;\r\n            height: 20px;\r\n            border-radius: 50%;\r\n            text-align: center;\r\n            line-height: 20px;\r\n            font-size: 10px;\r\n        }\r\n\r\n        .present-yes {\r\n            background: #dcfce7;\r\n            color: #166534;\r\n        }\r\n\r\n        .present-no {\r\n            background: #fee2e2;\r\n            color: #991b1b;\r\n        }\r\n\r\n        /* Visitors Table */\r\n        .visitors-section {\r\n            margin: 20px 0;\r\n        }\r\n\r\n        .visitors-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            margin-top: 12px;\r\n            font-size: 11px;\r\n            table-layout: fixed;\r\n        }\r\n\r\n        .visitors-table thead {\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n        }\r\n\r\n        .visitors-table th {\r\n            padding: 12px 10px;\r\n            text-align: left;\r\n            font-weight: 600;\r\n            color: white;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.4px;\r\n            border: none;\r\n            font-size: 10px;\r\n        }\r\n\r\n        .visitors-table td {\r\n            padding: 10px;\r\n            border-bottom: 1px solid #e2e8f0;\r\n        }\r\n\r\n        .visitors-table tbody tr:nth-child(even) {\r\n            background-color: #f8fafc;\r\n        }\r\n\r\n        .first-timer-badge {\r\n            background: #dbeafe;\r\n            color: #1e40af;\r\n            padding: 2px 6px;\r\n            border-radius: 3px;\r\n            font-size: 9px;\r\n            font-weight: 500;\r\n        }\r\n\r\n        /* Media Section */\r\n        .media-section {\r\n            background: #f0f9ff;\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #bae6fd;\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .media-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 12px;\r\n            margin-top: 12px;\r\n        }\r\n\r\n        .media-item {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #dbeafe;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 10px;\r\n        }\r\n\r\n        .media-label {\r\n            font-size: 11px;\r\n            color: #64748b;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .media-value {\r\n            font-size: 13px;\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n        }\r\n\r\n        /* Report Section */\r\n        .report-content {\r\n            margin: 20px 0;\r\n            padding: 20px;\r\n            background: #f8fafc;\r\n            border-radius: 10px;\r\n            border: 1px solid #e2e8f0;\r\n        }\r\n\r\n        .report-text {\r\n            font-size: 13px;\r\n            line-height: 1.6;\r\n            color: #475569;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        /* Footer */\r\n        .footer-section {\r\n            margin-top: 25px;\r\n            padding-top: 20px;\r\n            border-top: 2px solid #e2e8f0;\r\n            text-align: center;\r\n        }\r\n\r\n        .footer-text {\r\n            color: #475569;\r\n            font-size: 11px;\r\n            line-height: 1.6;\r\n            margin-bottom: 10px;\r\n        }\r\n\r\n        .bible-verse {\r\n            font-style: italic;\r\n            color: #3b82f6;\r\n            font-size: 12px;\r\n            font-weight: 500;\r\n            margin: 12px 0;\r\n            padding: 12px;\r\n            background: #eff6ff;\r\n            border-radius: 6px;\r\n            border-left: 3px solid #3b82f6;\r\n        }\r\n\r\n        /* Print Info */\r\n        .print-info {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-size: 10px;\r\n            margin-top: 15px;\r\n            padding-top: 12px;\r\n            border-top: 1px solid #e2e8f0;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Utility */\r\n        .text-center { text-align: center; }\r\n        .text-right { text-align: right; }\r\n        .text-mono { font-family: 'SF Mono', 'Monaco', 'Consolas', monospace; }\r\n        .mb-15 { margin-bottom: 15px; }\r\n        \r\n        .empty-state {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-style: italic;\r\n            padding: 25px;\r\n            background: #f8fafc;\r\n            border-radius: 8px;\r\n            margin: 10px 0;\r\n        }\r\n\r\n        /* Column widths */\r\n        .col-sn { width: 40px; text-align: center; }\r\n        .col-name { width: 180px; }\r\n        .col-role { width: 120px; }\r\n        .col-phone { width: 100px; }\r\n        .col-email { width: 150px; }\r\n        .col-present { width: 60px; text-align: center; }\r\n\r\n        .col-visitor-name { width: 160px; }\r\n        .col-visitor-phone { width: 100px; }\r\n        .col-visitor-type { width: 80px; }\r\n        .col-first-time { width: 80px; text-align: center; }\r\n        .col-follow-up { width: 100px; }\r\n        .col-status { width: 80px; text-align: center; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"report-container\">\r\n        <!-- Header -->\r\n        <div class=\"header-section\">\r\n            <div class=\"service-icon\">\r\n                <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                    <path d=\"M12 2L4 7v6.5C4 19 8 22 12 22s8-3 8-8.5V7l-8-5zm0 2.18l6 3.75v5.57c0 3.9-3.13 6.5-6 6.5s-6-2.6-6-6.5V7.93l6-3.75zM11 8v3H8v2h3v3h2v-3h3v-2h-3V8h-2z\"/>\r\n                </svg>\r\n            </div>\r\n            <div class=\"report-title\">{{ doc.service_name }}</div>\r\n            <div class=\"report-subtitle\">Service Instance Report</div>\r\n            <div class=\"service-badge\">Instance ID: {{ doc.name }}</div>\r\n        </div>\r\n\r\n        <!-- Service Information -->\r\n        <div class=\"service-info\">\r\n            <div class=\"info-grid\">\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Service Type</div>\r\n                    <div class=\"info-value info-highlight\">{{ doc.service or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Status</div>\r\n                    <div class=\"info-value\">\r\n                        {% if doc.status == 'Scheduled' %}\r\n                            <span class=\"status-badge status-scheduled\">{{ doc.status }}</span>\r\n                        {% elif doc.status == 'Ongoing' %}\r\n                            <span class=\"status-badge status-ongoing\">{{ doc.status }}</span>\r\n                        {% elif doc.status == 'Completed' %}\r\n                            <span class=\"status-badge status-completed\">{{ doc.status }}</span>\r\n                        {% elif doc.status == 'Cancelled' %}\r\n                            <span class=\"status-badge status-cancelled\">{{ doc.status }}</span>\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Service Date</div>\r\n                    <div class=\"info-value\">{{ frappe.format(doc.service_date, {'fieldtype': 'Date'}) }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Service Time</div>\r\n                    <div class=\"info-value\">{{ doc.actual_start_time or doc.service_time }} \r\n                        {% if doc.actual_end_time %}\r\n                            - {{ doc.actual_end_time }}\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Service Details -->\r\n        <div class=\"section-title\">\ud83d\udcc5 Service Details</div>\r\n        <div class=\"details-section\">\r\n            <div class=\"details-grid\">\r\n                <div class=\"detail-card\">\r\n                    <div class=\"detail-label\">Scheduled Time</div>\r\n                    <div class=\"detail-value\">{{ doc.service_time or \"Not set\" }}</div>\r\n                </div>\r\n                <div class=\"detail-card\">\r\n                    <div class=\"detail-label\">Actual Start</div>\r\n                    <div class=\"detail-value\">{{ doc.actual_start_time or \"Not recorded\" }}</div>\r\n                </div>\r\n                <div class=\"detail-card\">\r\n                    <div class=\"detail-label\">Actual End</div>\r\n                    <div class=\"detail-value\">{{ doc.actual_end_time or \"Not recorded\" }}</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Attendance Summary -->\r\n        <div class=\"section-title\">\ud83d\udc65 Attendance Summary</div>\r\n        <div class=\"attendance-section\">\r\n            <div class=\"attendance-grid\">\r\n                <div class=\"attendance-card\">\r\n                    <div class=\"attendance-label\">Men</div>\r\n                    <div class=\"attendance-value\">{{ doc.men_count or 0 }}</div>\r\n                </div>\r\n                <div class=\"attendance-card\">\r\n                    <div class=\"attendance-label\">Women</div>\r\n                    <div class=\"attendance-value\">{{ doc.women_count or 0 }}</div>\r\n                </div>\r\n                <div class=\"attendance-card\">\r\n                    <div class=\"attendance-label\">Children</div>\r\n                    <div class=\"attendance-value\">{{ doc.children_count or 0 }}</div>\r\n                </div>\r\n                <div class=\"attendance-card\">\r\n                    <div class=\"attendance-label\">First Timers</div>\r\n                    <div class=\"attendance-value\">{{ doc.first_timers or 0 }}</div>\r\n                </div>\r\n                <div class=\"attendance-card\">\r\n                    <div class=\"attendance-label\">New Converts</div>\r\n                    <div class=\"attendance-value\">{{ doc.new_converts or 0 }}</div>\r\n                </div>\r\n                <div class=\"attendance-card total-attendance\">\r\n                    <div class=\"attendance-label\">TOTAL ATTENDANCE</div>\r\n                    <div class=\"attendance-value\">{{ doc.total_attendance or 0 }}</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Collections -->\r\n        <div class=\"section-title\">\ud83d\udcb0 Collections</div>\r\n        <div class=\"collections-section\">\r\n            <div class=\"collections-grid\">\r\n                <div class=\"collection-card\">\r\n                    <div class=\"collection-label\">Total Offering</div>\r\n                    <div class=\"collection-value\">{{ frappe.utils.fmt_money(doc.total_offering or 0, currency='NGN') }}</div>\r\n                </div>\r\n                <div class=\"collection-card\">\r\n                    <div class=\"collection-label\">Total Tithe</div>\r\n                    <div class=\"collection-value\">{{ frappe.utils.fmt_money(doc.total_tithe or 0, currency='NGN') }}</div>\r\n                </div>\r\n                <div class=\"collection-card\">\r\n                    <div class=\"collection-label\">Special Offering</div>\r\n                    <div class=\"collection-value\">{{ frappe.utils.fmt_money(doc.special_offering or 0, currency='NGN') }}</div>\r\n                </div>\r\n                <div class=\"collection-card\">\r\n                    <div class=\"collection-label\">Other Collections</div>\r\n                    <div class=\"collection-value\">{{ frappe.utils.fmt_money(doc.other_collections or 0, currency='NGN') }}</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Leadership -->\r\n        <div class=\"section-title\">\ud83d\ude4f Service Leadership</div>\r\n        <div class=\"leadership-section\">\r\n            <div class=\"leadership-grid\">\r\n                <div class=\"leadership-card\">\r\n                    <div class=\"leadership-role\">Presiding Minister</div>\r\n                    <div class=\"leadership-name\">{{ doc.minister or \"Not assigned\" }}</div>\r\n                </div>\r\n                <div class=\"leadership-card\">\r\n                    <div class=\"leadership-role\">Worship Leader</div>\r\n                    <div class=\"leadership-name\">{{ doc.worship_leader or \"Not assigned\" }}</div>\r\n                </div>\r\n                <div class=\"leadership-card\">\r\n                    <div class=\"leadership-role\">Preacher</div>\r\n                    <div class=\"leadership-name\">{{ doc.preacher or doc.minister or \"Not assigned\" }}</div>\r\n                </div>\r\n                <div class=\"leadership-card\">\r\n                    <div class=\"leadership-role\">Choir</div>\r\n                    <div class=\"leadership-name\">{{ doc.choir or \"Not assigned\" }}</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Sermon Details -->\r\n        {% if doc.sermon_title %}\r\n        <div class=\"section-title\">\ud83d\udcd6 Sermon Details</div>\r\n        <div class=\"sermon-section\">\r\n            <div class=\"sermon-header\">\r\n                <div class=\"sermon-title\">\r\n                    <div class=\"info-label\">Sermon Title</div>\r\n                    <div class=\"info-value info-highlight\">{{ doc.sermon_title }}</div>\r\n                </div>\r\n                <div class=\"sermon-publisher\">\r\n                    <div class=\"info-label\">Bible Text</div>\r\n                    <div class=\"info-value\">{{ doc.sermon_text or \"Not specified\" }}</div>\r\n                </div>\r\n            </div>\r\n            {% if doc.sermon_notes %}\r\n            <div class=\"info-label\">Sermon Notes</div>\r\n            <div class=\"report-text\">{{ doc.sermon_notes|striptags|truncate(500) }}</div>\r\n            {% endif %}\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Ministry Team -->\r\n        {% if doc.ministry_team and doc.ministry_team|length > 0 %}\r\n        <div class=\"section-title\">\ud83d\udc65 Ministry Team</div>\r\n        <div class=\"ministry-section\">\r\n            <table class=\"team-table\">\r\n                <thead>\r\n                    <tr>\r\n                        <th class=\"col-sn\">#</th>\r\n                        <th class=\"col-name\">Member Name</th>\r\n                        <th class=\"col-role\">Ministry Role</th>\r\n                        <th class=\"col-phone\">Phone</th>\r\n                        <th class=\"col-email\">Email</th>\r\n                        <th class=\"col-present\">Present</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    {% for member in doc.ministry_team %}\r\n                    <tr>\r\n                        <td style=\"text-align: center;\">{{ loop.index }}</td>\r\n                        <td>{{ member.full_name or \"\" }}</td>\r\n                        <td>{{ member.ministry_role or \"Team Member\" }}</td>\r\n                        <td>{{ member.phone or \"\" }}</td>\r\n                        <td>{{ member.email or \"\" }}</td>\r\n                        <td style=\"text-align: center;\">\r\n                            {% if member.present %}\r\n                                <span class=\"present-badge present-yes\">\u2713</span>\r\n                            {% else %}\r\n                                <span class=\"present-badge present-no\">\u2717</span>\r\n                            {% endif %}\r\n                        </td>\r\n                    </tr>\r\n                    {% endfor %}\r\n                </tbody>\r\n            </table>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Service Visitors -->\r\n        {% if doc.service_visitors and doc.service_visitors|length > 0 %}\r\n        <div class=\"section-title\">\ud83d\udc64 Service Visitors</div>\r\n        <div class=\"visitors-section\">\r\n            <table class=\"visitors-table\">\r\n                <thead>\r\n                    <tr>\r\n                        <th class=\"col-sn\">#</th>\r\n                        <th class=\"col-visitor-name\">Visitor Name</th>\r\n                        <th class=\"col-visitor-phone\">Phone</th>\r\n                        <th class=\"col-visitor-type\">Visit Type</th>\r\n                        <th class=\"col-first-time\">First Time</th>\r\n                        <th class=\"col-follow-up\">Follow-up</th>\r\n                        <th class=\"col-status\">Status</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    {% for visitor in doc.service_visitors %}\r\n                    <tr>\r\n                        <td style=\"text-align: center;\">{{ loop.index }}</td>\r\n                        <td>{{ visitor.full_name or \"\" }}</td>\r\n                        <td>{{ visitor.phone or \"\" }}</td>\r\n                        <td>{{ visitor.visit_type or \"Visitor\" }}</td>\r\n                        <td style=\"text-align: center;\">\r\n                            {% if visitor.is_first_time %}\r\n                                <span class=\"first-timer-badge\">First</span>\r\n                            {% else %}\r\n                                <span style=\"color: #94a3b8; font-size: 9px;\">Return</span>\r\n                            {% endif %}\r\n                        </td>\r\n                        <td>{{ visitor.follow_up_assigned_to or \"Not assigned\" }}</td>\r\n                        <td style=\"text-align: center;\">\r\n                            {% if visitor.follow_up_status == 'Completed' %}\r\n                                <span style=\"color: #166534; font-size: 9px;\">\u2713 Done</span>\r\n                            {% elif visitor.follow_up_required %}\r\n                                <span style=\"color: #dc2626; font-size: 9px;\">Pending</span>\r\n                            {% else %}\r\n                                <span style=\"color: #94a3b8; font-size: 9px;\">-</span>\r\n                            {% endif %}\r\n                        </td>\r\n                    </tr>\r\n                    {% endfor %}\r\n                </tbody>\r\n            </table>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Media & Recording -->\r\n        {% if doc.audio_recording or doc.video_recording or doc.livestream_link %}\r\n        <div class=\"section-title\">\ud83c\udfa5 Media & Recording</div>\r\n        <div class=\"media-section\">\r\n            <div class=\"media-grid\">\r\n                {% if doc.audio_recording %}\r\n                <div class=\"media-item\">\r\n                    <span>\ud83c\udfb5</span>\r\n                    <div>\r\n                        <div class=\"media-label\">Audio Recording</div>\r\n                        <div class=\"media-value\">Available</div>\r\n                    </div>\r\n                </div>\r\n                {% endif %}\r\n                {% if doc.video_recording %}\r\n                <div class=\"media-item\">\r\n                    <span>\ud83c\udfac</span>\r\n                    <div>\r\n                        <div class=\"media-label\">Video Recording</div>\r\n                        <div class=\"media-value\">Available</div>\r\n                    </div>\r\n                </div>\r\n                {% endif %}\r\n                {% if doc.livestream_link %}\r\n                <div class=\"media-item\">\r\n                    <span>\ud83d\udce1</span>\r\n                    <div>\r\n                        <div class=\"media-label\">Livestream Link</div>\r\n                        <div class=\"media-value\">{{ doc.livestream_link|truncate(40) }}</div>\r\n                    </div>\r\n                </div>\r\n                {% endif %}\r\n                {% if doc.livestream_views %}\r\n                <div class=\"media-item\">\r\n                    <span>\ud83d\udc41\ufe0f</span>\r\n                    <div>\r\n                        <div class=\"media-label\">Livestream Views</div>\r\n                        <div class=\"media-value\">{{ doc.livestream_views }}</div>\r\n                    </div>\r\n                </div>\r\n                {% endif %}\r\n            </div>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Service Report -->\r\n        {% if doc.service_report %}\r\n        <div class=\"section-title\">\ud83d\udccb Service Report</div>\r\n        <div class=\"report-content\">\r\n            <div class=\"report-text\">\r\n                {{ doc.service_report|striptags|truncate(800) }}\r\n            </div>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Footer -->\r\n        <div class=\"footer-section\">\r\n            <div class=\"bible-verse\">\r\n                \"For where two or three gather in my name, there am I with them.\" - Matthew 18:20\r\n            </div>\r\n            <div class=\"footer-text\">\r\n                This service instance report documents the details, attendance, and outcomes of the church service.\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Print Info -->\r\n        <div class=\"print-info\">\r\n            Generated by Church Management System \u2022 {{ doc.name }} \u2022 Printed on: {{ frappe.utils.now_datetime().strftime('%Y-%m-%d %H:%M') }}\r\n        </div>\r\n    </div>\r\n</body>\r\n</html>",
