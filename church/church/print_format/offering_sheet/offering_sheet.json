{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2026-02-01 20:14:24.799482",
 "custom_format": 1,
 "default_print_language": "en-GB",
 "disabled": 0,
 "doc_type": "Offering Sheet",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap');\r\n        \r\n        @media print {\r\n            @page {\r\n                margin: 15mm 10mm 15mm 10mm;\r\n                size: A4 portrait;\r\n            }\r\n            \r\n            body { \r\n                margin: 0;\r\n                padding: 0;\r\n                -webkit-print-color-adjust: exact;\r\n            }\r\n            \r\n            .no-print { display: none !important; }\r\n            .page-break { page-break-after: always; break-after: page; }\r\n        }\r\n        \r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        body {\r\n            font-family: 'Inter', sans-serif;\r\n            background: white;\r\n            color: #1e293b;\r\n            line-height: 1.5;\r\n            font-size: 12px;\r\n        }\r\n\r\n        .report-container {\r\n            width: 100%;\r\n            max-width: 794px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        /* Header - Smaller & Compact */\r\n        .header-section {\r\n            text-align: center;\r\n            margin-bottom: 15px;\r\n            padding-bottom: 15px;\r\n            border-bottom: 2px solid #2563eb;\r\n            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);\r\n            padding: 15px 20px;\r\n            border-radius: 8px 8px 0 0;\r\n            color: white;\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .header-section::before {\r\n            content: '';\r\n            position: absolute;\r\n            top: -20%;\r\n            right: -10%;\r\n            width: 150px;\r\n            height: 150px;\r\n            background: rgba(255, 255, 255, 0.1);\r\n            border-radius: 50%;\r\n            z-index: 1;\r\n        }\r\n\r\n        .offering-icon {\r\n            width: 40px;\r\n            height: 40px;\r\n            background: rgba(255, 255, 255, 0.2);\r\n            border-radius: 50%;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            margin: 0 auto 8px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .offering-icon svg {\r\n            width: 20px;\r\n            height: 20px;\r\n            fill: white;\r\n        }\r\n\r\n        .report-title {\r\n            font-family: 'Playfair Display', serif;\r\n            font-size: 20px;\r\n            font-weight: 600;\r\n            margin: 0 0 5px 0;\r\n            letter-spacing: -0.5px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .report-subtitle {\r\n            font-size: 12px;\r\n            opacity: 0.9;\r\n            font-weight: 400;\r\n            margin-bottom: 5px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .offering-badge {\r\n            display: inline-block;\r\n            background: rgba(255, 255, 255, 0.2);\r\n            color: white;\r\n            padding: 4px 10px;\r\n            border-radius: 30px;\r\n            font-size: 10px;\r\n            font-weight: 600;\r\n            margin-top: 5px;\r\n            backdrop-filter: blur(8px);\r\n            position: relative;\r\n            z-index: 2;\r\n            border: 1px solid rgba(255, 255, 255, 0.3);\r\n        }\r\n\r\n        /* Offering Information - Smaller */\r\n        .offering-info {\r\n            margin-bottom: 15px;\r\n        }\r\n\r\n        .info-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 10px;\r\n            margin-bottom: 10px;\r\n        }\r\n\r\n        .info-card {\r\n            background: white;\r\n            padding: 12px;\r\n            border-radius: 6px;\r\n            border: 1px solid #e2e8f0;\r\n            border-top: 3px solid #3b82f6;\r\n        }\r\n\r\n        .info-label {\r\n            font-size: 9px;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.8px;\r\n            color: #64748b;\r\n            margin-bottom: 4px;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .info-value {\r\n            font-size: 13px;\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .info-highlight {\r\n            color: #2563eb;\r\n            font-weight: 700;\r\n        }\r\n\r\n        /* Section Titles */\r\n        .section-title {\r\n            font-family: 'Playfair Display', serif;\r\n            font-size: 16px;\r\n            color: #1e40af;\r\n            margin: 15px 0 10px 0;\r\n            padding-bottom: 6px;\r\n            border-bottom: 2px solid #3b82f6;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 6px;\r\n        }\r\n\r\n        /* Period Details - Smaller */\r\n        .period-section {\r\n            background: #f0f9ff;\r\n            padding: 15px;\r\n            border-radius: 8px;\r\n            border: 1px solid #bae6fd;\r\n            margin: 10px 0;\r\n        }\r\n\r\n        .period-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 10px;\r\n            margin-top: 8px;\r\n        }\r\n\r\n        .period-card {\r\n            background: white;\r\n            padding: 12px;\r\n            border-radius: 5px;\r\n            border: 1px solid #dbeafe;\r\n            text-align: center;\r\n        }\r\n\r\n        .period-label {\r\n            font-size: 9px;\r\n            color: #64748b;\r\n            margin-bottom: 4px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.6px;\r\n        }\r\n\r\n        .period-value {\r\n            font-size: 14px;\r\n            font-weight: 700;\r\n            color: #1e40af;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Offering Table - Removed Currency and Amount columns */\r\n        .offering-section {\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .offering-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            margin-top: 10px;\r\n            font-size: 10px;\r\n            table-layout: fixed;\r\n        }\r\n\r\n        .offering-table thead {\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n        }\r\n\r\n        .offering-table th {\r\n            padding: 10px 6px;\r\n            text-align: left;\r\n            font-weight: 600;\r\n            color: white;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.3px;\r\n            border: none;\r\n            font-size: 9px;\r\n        }\r\n\r\n        .offering-table td {\r\n            padding: 8px 6px;\r\n            border-bottom: 1px solid #e2e8f0;\r\n        }\r\n\r\n        .offering-table tbody tr:nth-child(even) {\r\n            background-color: #f8fafc;\r\n        }\r\n\r\n        /* Totals & Bank Section - Side by side layout */\r\n        .totals-bank-section {\r\n            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);\r\n            padding: 15px;\r\n            border-radius: 8px;\r\n            border: 1px solid #bae6fd;\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .totals-bank-grid {\r\n            display: grid;\r\n            grid-template-columns: 2fr 1fr;\r\n            gap: 15px;\r\n            margin-top: 0;\r\n        }\r\n\r\n        /* Grand Total Card */\r\n        .grand-total-card {\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n            color: white;\r\n            padding: 20px;\r\n            border: none;\r\n            border-radius: 8px;\r\n            text-align: center;\r\n            display: flex;\r\n            flex-direction: column;\r\n            justify-content: center;\r\n        }\r\n\r\n        .grand-total-label {\r\n            font-size: 11px;\r\n            color: rgba(255, 255, 255, 0.9);\r\n            margin-bottom: 8px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.8px;\r\n        }\r\n\r\n        .grand-total-value {\r\n            font-size: 26px;\r\n            font-weight: 700;\r\n            color: white;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Bank Account Card */\r\n        .bank-card {\r\n            background: white;\r\n            padding: 20px;\r\n            border-radius: 8px;\r\n            border: 1px solid #dbeafe;\r\n            text-align: center;\r\n            display: flex;\r\n            flex-direction: column;\r\n            justify-content: center;\r\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);\r\n        }\r\n\r\n        .bank-label {\r\n            font-size: 10px;\r\n            color: #64748b;\r\n            margin-bottom: 8px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.6px;\r\n        }\r\n\r\n        .bank-value {\r\n            font-size: 15px;\r\n            color: #1e293b;\r\n            font-weight: 700;\r\n            line-height: 1.4;\r\n        }\r\n\r\n        /* Prepared By */\r\n        .prepared-section {\r\n            margin: 12px 0;\r\n            padding: 15px;\r\n            background: #f8fafc;\r\n            border-radius: 8px;\r\n            border: 1px solid #e2e8f0;\r\n        }\r\n\r\n        .prepared-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 15px;\r\n            margin-top: 12px;\r\n        }\r\n\r\n        .prepared-item {\r\n            text-align: center;\r\n            padding: 12px;\r\n            background: white;\r\n            border-radius: 6px;\r\n            border: 1px solid #e2e8f0;\r\n        }\r\n\r\n        /* Footer */\r\n        .footer-section {\r\n            margin-top: 20px;\r\n            padding-top: 15px;\r\n            border-top: 2px solid #e2e8f0;\r\n            text-align: center;\r\n        }\r\n\r\n        .footer-text {\r\n            color: #475569;\r\n            font-size: 10px;\r\n            line-height: 1.5;\r\n            margin-bottom: 8px;\r\n        }\r\n\r\n        .bible-verse {\r\n            font-style: italic;\r\n            color: #3b82f6;\r\n            font-size: 11px;\r\n            font-weight: 500;\r\n            margin: 10px 0;\r\n            padding: 10px;\r\n            background: #eff6ff;\r\n            border-radius: 5px;\r\n            border-left: 3px solid #3b82f6;\r\n        }\r\n\r\n        /* Print Info */\r\n        .print-info {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-size: 9px;\r\n            margin-top: 12px;\r\n            padding-top: 10px;\r\n            border-top: 1px solid #e2e8f0;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Utility */\r\n        .text-center { text-align: center; }\r\n        .text-right { text-align: right; }\r\n        .text-mono { font-family: 'SF Mono', 'Monaco', 'Consolas', monospace; }\r\n        \r\n        .empty-state {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-style: italic;\r\n            padding: 20px;\r\n            background: #f8fafc;\r\n            border-radius: 6px;\r\n            margin: 8px 0;\r\n        }\r\n\r\n        /* Column widths - Updated for removed columns */\r\n        .col-sn { width: 40px; text-align: center; }\r\n        .col-date { width: 80px; }\r\n        .col-day { width: 50px; }\r\n        .col-program { width: 140px; }\r\n        .col-type { width: 120px; }\r\n        .col-lc { width: 120px; text-align: right; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"report-container\">\r\n        <!-- Header - Smaller -->\r\n        <div class=\"header-section\">\r\n            <div class=\"offering-icon\">\r\n                <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                    <path d=\"M12 2L4 7v6.5C4 19 8 22 12 22s8-3 8-8.5V7l-8-5zm0 2.18l6 3.75v5.57c0 3.9-3.13 6.5-6 6.5s-6-2.6-6-6.5V7.93l6-3.75zM11 8v3H8v2h3v3h2v-3h3v-2h-3V8h-2z\"/>\r\n                </svg>\r\n            </div>\r\n            <div class=\"report-title\">OFFERING SHEET</div>\r\n            <div class=\"report-subtitle\">Financial Offering Record</div>\r\n            <div class=\"offering-badge\">Sheet ID: {{ doc.name }}</div>\r\n        </div>\r\n\r\n        <!-- Offering Information - Smaller -->\r\n        <div class=\"offering-info\">\r\n            <div class=\"info-grid\">\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Company</div>\r\n                    <div class=\"info-value info-highlight\">{{ doc.company or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Branch</div>\r\n                    <div class=\"info-value\">{{ doc.branch or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Reporting Date</div>\r\n                    <div class=\"info-value\">{{ frappe.format(doc.reporting_date, {'fieldtype': 'Date'}) }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Month</div>\r\n                    <div class=\"info-value\">{{ doc.month or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Prepared By</div>\r\n                    <div class=\"info-value\">{{ doc.prepared_by or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Status</div>\r\n                    <div class=\"info-value\">\r\n                        {% if doc.docstatus == 0 %}\r\n                            <span style=\"color: #92400e; font-weight: 600;\">Draft</span>\r\n                        {% elif doc.docstatus == 1 %}\r\n                            <span style=\"color: #166534; font-weight: 600;\">Submitted</span>\r\n                        {% elif doc.docstatus == 2 %}\r\n                            <span style=\"color: #991b1b; font-weight: 600;\">Cancelled</span>\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Period Details - Smaller -->\r\n        <div class=\"section-title\">\ud83d\udcc5 Period Details</div>\r\n        <div class=\"period-section\">\r\n            <div class=\"period-grid\">\r\n                <div class=\"period-card\">\r\n                    <div class=\"period-label\">From Date</div>\r\n                    <div class=\"period-value\">{{ frappe.format(doc.date_from, {'fieldtype': 'Date'}) }}</div>\r\n                </div>\r\n                <div class=\"period-card\">\r\n                    <div class=\"period-label\">To Date</div>\r\n                    <div class=\"period-value\">{{ frappe.format(doc.date_to, {'fieldtype': 'Date'}) }}</div>\r\n                </div>\r\n                <div class=\"period-card\">\r\n                    <div class=\"period-label\">Duration</div>\r\n                    <div class=\"period-value\">\r\n                        {% set from_date = frappe.utils.getdate(doc.date_from) %}\r\n                        {% set to_date = frappe.utils.getdate(doc.date_to) %}\r\n                        {% set diff = (to_date - from_date).days + 1 %}\r\n                        {{ diff }} day{% if diff > 1 %}s{% endif %}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Offering Entries - Removed Currency and Amount columns -->\r\n        <div class=\"section-title\">\ud83d\udcb0 Offering Entries</div>\r\n        <div class=\"offering-section\">\r\n            {% if doc.offering and doc.offering|length > 0 %}\r\n            <table class=\"offering-table\">\r\n                <thead>\r\n                    <tr>\r\n                        <th class=\"col-sn\">#</th>\r\n                        <th class=\"col-date\">Date</th>\r\n                        <th class=\"col-day\">Day</th>\r\n                        <th class=\"col-program\">Program</th>\r\n                        <th class=\"col-type\">Type</th>\r\n                        <th class=\"col-lc\">Amount (LC)</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    {% for offering in doc.offering %}\r\n                    <tr>\r\n                        <td style=\"text-align: center;\">{{ loop.index }}</td>\r\n                        <td>{{ frappe.format(offering.date, {'fieldtype': 'Date'}) }}</td>\r\n                        <td>{{ offering.day or \"N/A\" }}</td>\r\n                        <td>{{ offering.programme or \"Not specified\" }}</td>\r\n                        <td>{{ offering.offering_type or \"Not specified\" }}</td>\r\n                        <td style=\"text-align: right; font-family: 'SF Mono', monospace; font-weight: 600; color: #2563eb;\">\r\n                            {{ frappe.utils.fmt_money(offering.amount_in_lc or offering.amount_paid or 0, currency=doc.currency or 'NGN') }}\r\n                        </td>\r\n                    </tr>\r\n                    {% endfor %}\r\n                </tbody>\r\n            </table>\r\n            {% else %}\r\n            <div class=\"empty-state\">\r\n                No offering entries recorded for this period.\r\n            </div>\r\n            {% endif %}\r\n        </div>\r\n\r\n        <!-- Totals & Bank Section - Side by side -->\r\n        <div class=\"section-title\">\ud83e\uddee Summary</div>\r\n        <div class=\"totals-bank-section\">\r\n            <div class=\"totals-bank-grid\">\r\n                <!-- Grand Total Card (Left - Bigger) -->\r\n                <div class=\"grand-total-card\">\r\n                    <div class=\"grand-total-label\">GRAND TOTAL OFFERING</div>\r\n                    <div class=\"grand-total-value\">\r\n                        {{ frappe.utils.fmt_money(doc.total, currency=doc.currency or 'NGN') }}\r\n                    </div>\r\n                </div>\r\n                \r\n                <!-- Bank Account Card (Right - Smaller) -->\r\n                <div class=\"bank-card\">\r\n                    <div class=\"bank-label\">Bank Account</div>\r\n                    <div class=\"bank-value\">{{ doc.bank_account or \"Not specified\" }}</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Prepared By Section -->\r\n        <div class=\"section-title\">\u270d\ufe0f Approval</div>\r\n        <div class=\"prepared-section\">\r\n            <div class=\"prepared-grid\">\r\n                <div class=\"prepared-item\">\r\n                    <div class=\"info-label\">Prepared By</div>\r\n                    <div class=\"info-value\" style=\"margin-top: 25px;\">\r\n                        _________________________\r\n                    </div>\r\n                    <div style=\"margin-top: 6px; font-size: 10px; color: #64748b;\">\r\n                        {{ doc.prepared_by or \"Name & Signature\" }}\r\n                    </div>\r\n                </div>\r\n                <div class=\"prepared-item\">\r\n                    <div class=\"info-label\">Approved By</div>\r\n                    <div class=\"info-value\" style=\"margin-top: 25px;\">\r\n                        _________________________\r\n                    </div>\r\n                    <div style=\"margin-top: 6px; font-size: 10px; color: #64748b;\">\r\n                        Church Treasurer/Pastor\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Footer -->\r\n        <div class=\"footer-section\">\r\n            <div class=\"bible-verse\">\r\n                \"Each of you should give what you have decided in your heart to give, \r\n                not reluctantly or under compulsion, for God loves a cheerful giver.\" - 2 Corinthians 9:7\r\n            </div>\r\n            <div class=\"footer-text\">\r\n                This offering sheet documents the financial contributions received during the specified period.\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Print Info -->\r\n        <div class=\"print-info\">\r\n            Generated by Church Management System \u2022 {{ doc.name }} \u2022 Printed on: {{ frappe.utils.now_datetime().strftime('%Y-%m-%d %H:%M') }}\r\n        </div>\r\n    </div>\r\n</body>\r\n</html>",
