{
 "absolute_value": 0,
 "align_labels_right": 0,
 "creation": "2026-01-29 21:01:01.266299",
 "custom_format": 1,
 "default_print_language": "en-GB",
 "disabled": 0,
 "doc_type": "Visitor",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap');\r\n        \r\n        @media print {\r\n            @page {\r\n                margin: 15mm 10mm 15mm 10mm;\r\n                size: A4 portrait;\r\n            }\r\n            \r\n            body { \r\n                margin: 0;\r\n                padding: 0;\r\n                -webkit-print-color-adjust: exact;\r\n            }\r\n            \r\n            .no-print { display: none !important; }\r\n            .page-break { page-break-after: always; break-after: page; }\r\n        }\r\n        \r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        body {\r\n            font-family: 'Inter', sans-serif;\r\n            background: white;\r\n            color: #1e293b;\r\n            line-height: 1.5;\r\n            font-size: 13px;\r\n        }\r\n\r\n        .report-container {\r\n            width: 100%;\r\n            max-width: 794px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        /* Header - Blue Theme */\r\n        .header-section {\r\n            text-align: center;\r\n            margin-bottom: 20px;\r\n            padding-bottom: 20px;\r\n            border-bottom: 3px solid #2563eb;\r\n            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 100%);\r\n            padding: 25px 30px;\r\n            border-radius: 10px 10px 0 0;\r\n            color: white;\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .header-section::before {\r\n            content: '';\r\n            position: absolute;\r\n            top: -30%;\r\n            right: -10%;\r\n            width: 200px;\r\n            height: 200px;\r\n            background: rgba(255, 255, 255, 0.1);\r\n            border-radius: 50%;\r\n            z-index: 1;\r\n        }\r\n\r\n        .visitor-icon {\r\n            width: 50px;\r\n            height: 50px;\r\n            background: rgba(255, 255, 255, 0.2);\r\n            border-radius: 50%;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            margin: 0 auto 12px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .visitor-icon svg {\r\n            width: 25px;\r\n            height: 25px;\r\n            fill: white;\r\n        }\r\n\r\n        .report-title {\r\n            font-family: 'Playfair Display', serif;\r\n            font-size: 26px;\r\n            font-weight: 600;\r\n            margin: 0 0 8px 0;\r\n            letter-spacing: -0.5px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .report-subtitle {\r\n            font-size: 15px;\r\n            opacity: 0.9;\r\n            font-weight: 400;\r\n            margin-bottom: 8px;\r\n            position: relative;\r\n            z-index: 2;\r\n        }\r\n\r\n        .visitor-badge {\r\n            display: inline-block;\r\n            background: rgba(255, 255, 255, 0.2);\r\n            color: white;\r\n            padding: 6px 15px;\r\n            border-radius: 40px;\r\n            font-size: 12px;\r\n            font-weight: 600;\r\n            margin-top: 8px;\r\n            backdrop-filter: blur(8px);\r\n            position: relative;\r\n            z-index: 2;\r\n            border: 1px solid rgba(255, 255, 255, 0.3);\r\n        }\r\n\r\n        /* Visitor Information */\r\n        .visitor-info {\r\n            margin-bottom: 20px;\r\n        }\r\n\r\n        .info-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 12px;\r\n            margin-bottom: 15px;\r\n        }\r\n\r\n        .info-card {\r\n            background: white;\r\n            padding: 18px;\r\n            border-radius: 8px;\r\n            border: 1px solid #e2e8f0;\r\n            border-top: 4px solid #3b82f6;\r\n            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.04);\r\n        }\r\n\r\n        .info-label {\r\n            font-size: 10px;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.9px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .info-value {\r\n            font-size: 15px;\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .info-highlight {\r\n            color: #2563eb;\r\n            font-weight: 700;\r\n        }\r\n\r\n        /* Status Badges */\r\n        .status-badge {\r\n            display: inline-block;\r\n            padding: 5px 10px;\r\n            border-radius: 5px;\r\n            font-size: 10px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.4px;\r\n        }\r\n\r\n        .status-new {\r\n            background: #dbeafe;\r\n            color: #1e40af;\r\n        }\r\n\r\n        .status-follow-up {\r\n            background: #fef3c7;\r\n            color: #92400e;\r\n        }\r\n\r\n        .status-converted {\r\n            background: #dcfce7;\r\n            color: #166534;\r\n        }\r\n\r\n        .status-member {\r\n            background: #bbf7d0;\r\n            color: #166534;\r\n        }\r\n\r\n        .status-lost {\r\n            background: #fecaca;\r\n            color: #991b1b;\r\n        }\r\n\r\n        .status-not-interested {\r\n            background: #f3f4f6;\r\n            color: #6b7280;\r\n        }\r\n\r\n        /* Section Titles */\r\n        .section-title {\r\n            font-family: 'Playfair Display', serif;\r\n            font-size: 18px;\r\n            color: #1e40af;\r\n            margin: 20px 0 15px 0;\r\n            padding-bottom: 8px;\r\n            border-bottom: 2px solid #3b82f6;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 8px;\r\n        }\r\n\r\n        /* Visit Details */\r\n        .visit-details {\r\n            background: #f0f9ff;\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #bae6fd;\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .visit-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 12px;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .visit-card {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #dbeafe;\r\n        }\r\n\r\n        /* Contact Information */\r\n        .contact-section {\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .contact-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 12px;\r\n            margin-top: 12px;\r\n        }\r\n\r\n        /* Spiritual Information */\r\n        .spiritual-section {\r\n            background: #f8fafc;\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #e2e8f0;\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .spiritual-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 12px;\r\n            margin-top: 12px;\r\n        }\r\n\r\n        .spiritual-card {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #e2e8f0;\r\n            text-align: center;\r\n        }\r\n\r\n        .spiritual-label {\r\n            font-size: 11px;\r\n            color: #64748b;\r\n            margin-bottom: 8px;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .spiritual-value {\r\n            font-size: 14px;\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .spiritual-check {\r\n            font-size: 20px;\r\n            color: #059669;\r\n            font-weight: bold;\r\n        }\r\n\r\n        .spiritual-cross {\r\n            font-size: 20px;\r\n            color: #dc2626;\r\n            font-weight: bold;\r\n        }\r\n\r\n        /* Follow-up Section */\r\n        .followup-section {\r\n            margin: 20px 0;\r\n        }\r\n\r\n        .followup-summary {\r\n            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #bae6fd;\r\n            margin-bottom: 15px;\r\n        }\r\n\r\n        .followup-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(4, 1fr);\r\n            gap: 12px;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .followup-card {\r\n            background: white;\r\n            padding: 15px;\r\n            border-radius: 6px;\r\n            border: 1px solid #dbeafe;\r\n            text-align: center;\r\n        }\r\n\r\n        .followup-label {\r\n            font-size: 10px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.7px;\r\n        }\r\n\r\n        .followup-value {\r\n            font-size: 16px;\r\n            font-weight: 700;\r\n            color: #1e40af;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Follow-up History Table */\r\n        .history-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            margin-top: 15px;\r\n            font-size: 11px;\r\n        }\r\n\r\n        .history-table thead {\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n        }\r\n\r\n        .history-table th {\r\n            padding: 12px 10px;\r\n            text-align: left;\r\n            font-weight: 600;\r\n            color: white;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.4px;\r\n            border: none;\r\n            font-size: 10px;\r\n        }\r\n\r\n        .history-table td {\r\n            padding: 10px;\r\n            border-bottom: 1px solid #e2e8f0;\r\n        }\r\n\r\n        .history-table tbody tr:nth-child(even) {\r\n            background-color: #f8fafc;\r\n        }\r\n\r\n        /* Ministry Interests & Prayer Requests */\r\n        .interests-section {\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .interests-card {\r\n            background: #f8fafc;\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #e2e8f0;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .interests-label {\r\n            font-size: 12px;\r\n            color: #64748b;\r\n            margin-bottom: 8px;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .interests-content {\r\n            font-size: 13px;\r\n            line-height: 1.6;\r\n            color: #475569;\r\n        }\r\n\r\n        /* Notes Section */\r\n        .notes-section {\r\n            margin: 15px 0;\r\n        }\r\n\r\n        .notes-card {\r\n            background: #f0f9ff;\r\n            padding: 20px;\r\n            border-radius: 10px;\r\n            border: 1px solid #bae6fd;\r\n            margin-top: 10px;\r\n        }\r\n\r\n        .notes-content {\r\n            font-size: 13px;\r\n            line-height: 1.6;\r\n            color: #475569;\r\n        }\r\n\r\n        /* Footer */\r\n        .footer-section {\r\n            margin-top: 25px;\r\n            padding-top: 20px;\r\n            border-top: 2px solid #e2e8f0;\r\n            text-align: center;\r\n        }\r\n\r\n        .footer-text {\r\n            color: #475569;\r\n            font-size: 11px;\r\n            line-height: 1.6;\r\n            margin-bottom: 10px;\r\n        }\r\n\r\n        .bible-verse {\r\n            font-style: italic;\r\n            color: #3b82f6;\r\n            font-size: 12px;\r\n            font-weight: 500;\r\n            margin: 12px 0;\r\n            padding: 12px;\r\n            background: #eff6ff;\r\n            border-radius: 6px;\r\n            border-left: 3px solid #3b82f6;\r\n        }\r\n\r\n        /* Print Info */\r\n        .print-info {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-size: 10px;\r\n            margin-top: 15px;\r\n            padding-top: 12px;\r\n            border-top: 1px solid #e2e8f0;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Utility */\r\n        .text-center { text-align: center; }\r\n        .text-right { text-align: right; }\r\n        .text-mono { font-family: 'SF Mono', 'Monaco', 'Consolas', monospace; }\r\n        .mb-10 { margin-bottom: 10px; }\r\n        \r\n        .empty-state {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-style: italic;\r\n            padding: 25px;\r\n            background: #f8fafc;\r\n            border-radius: 8px;\r\n            margin: 10px 0;\r\n        }\r\n\r\n        /* Check marks */\r\n        .check-yes {\r\n            color: #059669;\r\n            font-weight: bold;\r\n        }\r\n\r\n        .check-no {\r\n            color: #dc2626;\r\n            font-weight: bold;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"report-container\">\r\n        <!-- Header -->\r\n        <div class=\"header-section\">\r\n            <div class=\"visitor-icon\">\r\n                <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                    <path d=\"M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z\"/>\r\n                </svg>\r\n            </div>\r\n            <div class=\"report-title\">Visitor Record</div>\r\n            <div class=\"report-subtitle\">Welcome & Follow-up Information</div>\r\n            <div class=\"visitor-badge\">Visitor ID: {{ doc.name }}</div>\r\n        </div>\r\n\r\n        <!-- Visitor Information -->\r\n        <div class=\"visitor-info\">\r\n            <div class=\"info-grid\">\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Full Name</div>\r\n                    <div class=\"info-value info-highlight\">{{ doc.full_name }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Conversion Status</div>\r\n                    <div class=\"info-value\">\r\n                        {% if doc.conversion_status == 'New Visitor' %}\r\n                            <span class=\"status-badge status-new\">{{ doc.conversion_status }}</span>\r\n                        {% elif doc.conversion_status == 'In Follow-up' %}\r\n                            <span class=\"status-badge status-follow-up\">{{ doc.conversion_status }}</span>\r\n                        {% elif doc.conversion_status == 'Converted to Member' %}\r\n                            <span class=\"status-badge status-converted\">{{ doc.conversion_status }}</span>\r\n                        {% elif doc.conversion_status == 'Active Member' %}\r\n                            <span class=\"status-badge status-member\">{{ doc.conversion_status }}</span>\r\n                        {% elif doc.conversion_status == 'Lost Contact' %}\r\n                            <span class=\"status-badge status-lost\">{{ doc.conversion_status }}</span>\r\n                        {% elif doc.conversion_status == 'Not Interested' %}\r\n                            <span class=\"status-badge status-not-interested\">{{ doc.conversion_status }}</span>\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Gender</div>\r\n                    <div class=\"info-value\">{{ doc.gender }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Date of Birth</div>\r\n                    <div class=\"info-value\">{{ frappe.format(doc.date_of_birth, {'fieldtype': 'Date'}) or \"Not provided\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Age Category</div>\r\n                    <div class=\"info-value\">{{ doc.age_category or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Marital Status</div>\r\n                    <div class=\"info-value\">{{ doc.marital_status or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Occupation</div>\r\n                    <div class=\"info-value\">{{ doc.occupation or \"Not specified\" }}</div>\r\n                </div>\r\n                {% if doc.date_converted %}\r\n                <div class=\"info-card\" style=\"grid-column: span 2; background: #f0fdf4; border-color: #86efac;\">\r\n                    <div class=\"info-label\">Date Converted to Member</div>\r\n                    <div class=\"info-value info-highlight\">{{ frappe.format(doc.date_converted, {'fieldtype': 'Date'}) }}</div>\r\n                </div>\r\n                {% endif %}\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Visit Details -->\r\n        <div class=\"section-title\">\ud83d\udcc5 Visit Information</div>\r\n        <div class=\"visit-details\">\r\n            <div class=\"visit-grid\">\r\n                <div class=\"visit-card\">\r\n                    <div class=\"info-label\">Date of Visit</div>\r\n                    <div class=\"info-value\">{{ frappe.format(doc.date_of_visit, {'fieldtype': 'Date'}) }}</div>\r\n                </div>\r\n                <div class=\"visit-card\">\r\n                    <div class=\"info-label\">Service Attended</div>\r\n                    <div class=\"info-value\">{{ doc.service_name or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"visit-card\">\r\n                    <div class=\"info-label\">Branch</div>\r\n                    <div class=\"info-value\">{{ doc.branch or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"visit-card\">\r\n                    <div class=\"info-label\">Visit Type</div>\r\n                    <div class=\"info-value\">{{ doc.visit_type or \"First Time Visitor\" }}</div>\r\n                </div>\r\n                <div class=\"visit-card\">\r\n                    <div class=\"info-label\">Reason for Visit</div>\r\n                    <div class=\"info-value\">{{ doc.reason_for_visit or \"Not specified\" }}</div>\r\n                </div>\r\n                <div class=\"visit-card\">\r\n                    <div class=\"info-label\">How Did You Hear</div>\r\n                    <div class=\"info-value\">{{ doc.how_did_you_hear or \"Not specified\" }}</div>\r\n                </div>\r\n                {% if doc.referrer_name %}\r\n                <div class=\"visit-card\" style=\"grid-column: span 3; background: #eff6ff;\">\r\n                    <div class=\"info-label\">Referred By</div>\r\n                    <div class=\"info-value info-highlight\">{{ doc.referrer_name }}</div>\r\n                </div>\r\n                {% endif %}\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Contact Information -->\r\n        <div class=\"section-title\">\ud83d\udcde Contact Information</div>\r\n        <div class=\"contact-section\">\r\n            <div class=\"contact-grid\">\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Mobile Phone</div>\r\n                    <div class=\"info-value\">{{ doc.mobile_phone }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Alternative Phone</div>\r\n                    <div class=\"info-value\">{{ doc.alternative_phone or \"Not provided\" }}</div>\r\n                </div>\r\n                <div class=\"info-card\">\r\n                    <div class=\"info-label\">Email Address</div>\r\n                    <div class=\"info-value\">{{ doc.email or \"Not provided\" }}</div>\r\n                </div>\r\n                {% if doc.address or doc.city %}\r\n                <div class=\"info-card\" style=\"grid-column: span 2;\">\r\n                    <div class=\"info-label\">Address</div>\r\n                    <div class=\"info-value\">\r\n                        {{ doc.address or \"\" }}\r\n                        {% if doc.city %}<br>{{ doc.city }}{% endif %}\r\n                        {% if doc.state %}, {{ doc.state }}{% endif %}\r\n                        {% if doc.country %}, {{ doc.country }}{% endif %}\r\n                    </div>\r\n                </div>\r\n                {% endif %}\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Spiritual Information -->\r\n        <div class=\"section-title\">\ud83d\ude4f Spiritual Information</div>\r\n        <div class=\"spiritual-section\">\r\n            <div class=\"spiritual-grid\">\r\n                <div class=\"spiritual-card\">\r\n                    <div class=\"spiritual-label\">Born Again</div>\r\n                    <div class=\"spiritual-value\">\r\n                        {% if doc.is_born_again %}\r\n                            <span class=\"check-yes\">\u2713 Yes</span>\r\n                        {% else %}\r\n                            <span class=\"check-no\">\u2717 No</span>\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n                <div class=\"spiritual-card\">\r\n                    <div class=\"spiritual-label\">Interested in Membership</div>\r\n                    <div class=\"spiritual-value\">\r\n                        {% if doc.interested_in_membership %}\r\n                            <span class=\"check-yes\">\u2713 Yes</span>\r\n                        {% else %}\r\n                            <span class=\"check-no\">\u2717 No</span>\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n                <div class=\"spiritual-card\">\r\n                    <div class=\"spiritual-label\">Interested in Baptism</div>\r\n                    <div class=\"spiritual-value\">\r\n                        {% if doc.interested_in_baptism %}\r\n                            <span class=\"check-yes\">\u2713 Yes</span>\r\n                        {% else %}\r\n                            <span class=\"check-no\">\u2717 No</span>\r\n                        {% endif %}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            {% if doc.home_church %}\r\n            <div class=\"info-card\" style=\"margin-top: 15px;\">\r\n                <div class=\"info-label\">Home Church (if any)</div>\r\n                <div class=\"info-value\">{{ doc.home_church }}</div>\r\n            </div>\r\n            {% endif %}\r\n        </div>\r\n\r\n        <!-- Ministry Interests -->\r\n        {% if doc.ministry_interests %}\r\n        <div class=\"section-title\">\ud83c\udfaf Ministry Interests</div>\r\n        <div class=\"interests-section\">\r\n            <div class=\"interests-card\">\r\n                <div class=\"interests-content\">{{ doc.ministry_interests }}</div>\r\n            </div>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Prayer Requests -->\r\n        {% if doc.prayer_requests %}\r\n        <div class=\"section-title\">\ud83d\ude4f Prayer Requests</div>\r\n        <div class=\"interests-section\">\r\n            <div class=\"interests-card\">\r\n                <div class=\"interests-content\">{{ doc.prayer_requests }}</div>\r\n            </div>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Follow-up Information -->\r\n        <div class=\"section-title\">\ud83d\udccb Follow-up Management</div>\r\n        <div class=\"followup-section\">\r\n            <div class=\"followup-summary\">\r\n                <div class=\"followup-grid\">\r\n                    <div class=\"followup-card\">\r\n                        <div class=\"followup-label\">Total Follow-ups</div>\r\n                        <div class=\"followup-value\">{{ doc.follow_up_count or 0 }}</div>\r\n                    </div>\r\n                    <div class=\"followup-card\">\r\n                        <div class=\"followup-label\">Last Follow-up</div>\r\n                        <div class=\"followup-value\">{{ doc.last_follow_up_date or \"None\" }}</div>\r\n                    </div>\r\n                    <div class=\"followup-card\">\r\n                        <div class=\"followup-label\">Next Follow-up</div>\r\n                        <div class=\"followup-value\">{{ doc.next_follow_up_date or \"Not scheduled\" }}</div>\r\n                    </div>\r\n                    <div class=\"followup-card\">\r\n                        <div class=\"followup-label\">Coordinator</div>\r\n                        <div class=\"followup-value\">{{ doc.follow_up_coordinator or \"Not assigned\" }}</div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n\r\n            <!-- Follow-up History Table -->\r\n            {% if doc.follow_up_history and doc.follow_up_history|length > 0 %}\r\n            <div class=\"section-title\" style=\"font-size: 16px; margin-top: 20px;\">\ud83d\udcdd Follow-up History</div>\r\n            <table class=\"history-table\">\r\n                <thead>\r\n                    <tr>\r\n                        <th style=\"width: 90px;\">Date</th>\r\n                        <th style=\"width: 100px;\">Method</th>\r\n                        <th style=\"width: 150px;\">Coordinator</th>\r\n                        <th style=\"width: 200px;\">Notes</th>\r\n                        <th style=\"width: 100px;\">Next Action</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    {% for followup in doc.follow_up_history %}\r\n                    <tr>\r\n                        <td>{{ frappe.format(followup.follow_up_date, {'fieldtype': 'Date'}) }}</td>\r\n                        <td>{{ followup.follow_up_method }}</td>\r\n                        <td>{{ followup.follow_up_coordinator }}</td>\r\n                        <td>{{ followup.notes|striptags|truncate(80) }}</td>\r\n                        <td>{{ followup.next_action or \"\" }}</td>\r\n                    </tr>\r\n                    {% endfor %}\r\n                </tbody>\r\n            </table>\r\n            {% else %}\r\n            <div class=\"empty-state\">\r\n                No follow-up history recorded yet.\r\n            </div>\r\n            {% endif %}\r\n        </div>\r\n\r\n        <!-- Additional Notes -->\r\n        {% if doc.notes %}\r\n        <div class=\"section-title\">\ud83d\udcdd Additional Notes</div>\r\n        <div class=\"notes-section\">\r\n            <div class=\"notes-card\">\r\n                <div class=\"notes-content\">\r\n                    {{ doc.notes|striptags|truncate(1000) }}\r\n                </div>\r\n            </div>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Footer -->\r\n        <div class=\"footer-section\">\r\n            <div class=\"bible-verse\">\r\n                \"For the Son of Man came to seek and to save the lost.\" - Luke 19:10\r\n            </div>\r\n            <div class=\"footer-text\">\r\n                Every visitor is a precious soul loved by God.<br>\r\n                This record helps ensure effective follow-up and discipleship.\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Print Info -->\r\n        <div class=\"print-info\">\r\n            Generated by Church Management System \u2022 {{ doc.name }} \u2022 Printed on: {{ frappe.utils.now_datetime().strftime('%Y-%m-%d %H:%M') }}\r\n        </div>\r\n    </div>\r\n</body>\r\n</html>",
