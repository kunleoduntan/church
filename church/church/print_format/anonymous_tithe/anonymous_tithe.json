 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\r\n        \r\n        @media print {\r\n            @page {\r\n                margin: 15mm 10mm 15mm 10mm;\r\n                size: A4 portrait;\r\n            }\r\n            \r\n            body { \r\n                margin: 0;\r\n                padding: 0;\r\n                -webkit-print-color-adjust: exact;\r\n            }\r\n            \r\n            .no-print { display: none !important; }\r\n            .page-break { page-break-after: always; }\r\n        }\r\n        \r\n        * {\r\n            margin: 0;\r\n            padding: 0;\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        body {\r\n            font-family: 'Inter', sans-serif;\r\n            background: white;\r\n            color: #1e293b;\r\n            line-height: 1.4;\r\n            font-size: 12px;\r\n        }\r\n\r\n        .report-container {\r\n            width: 100%;\r\n            max-width: 794px;\r\n            margin: 0 auto;\r\n        }\r\n\r\n        /* Header */\r\n        .header-section {\r\n            text-align: center;\r\n            margin-bottom: 20px;\r\n            padding-bottom: 15px;\r\n            border-bottom: 2px solid #dc2626;\r\n        }\r\n\r\n        .report-title {\r\n            color: #dc2626;\r\n            font-size: 22px;\r\n            font-weight: 700;\r\n            margin: 0 0 8px 0;\r\n            letter-spacing: -0.5px;\r\n        }\r\n\r\n        .report-subtitle {\r\n            color: #64748b;\r\n            font-size: 14px;\r\n            margin: 0;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .batch-badge {\r\n            display: inline-block;\r\n            background: #dc2626;\r\n            color: white;\r\n            padding: 6px 16px;\r\n            border-radius: 4px;\r\n            font-size: 11px;\r\n            font-weight: 600;\r\n            margin-top: 8px;\r\n            letter-spacing: 0.3px;\r\n        }\r\n\r\n        /* Batch Information */\r\n        .batch-info {\r\n            margin-bottom: 20px;\r\n            background: #fef2f2;\r\n            padding: 16px;\r\n            border-radius: 8px;\r\n            border: 1px solid #fecaca;\r\n        }\r\n\r\n        .info-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 12px;\r\n        }\r\n\r\n        .info-item {\r\n            display: flex;\r\n            flex-direction: column;\r\n            min-width: 0;\r\n        }\r\n\r\n        .info-label {\r\n            font-size: 10px;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.8px;\r\n            color: #991b1b;\r\n            margin-bottom: 4px;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .info-value {\r\n            font-size: 13px;\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n            white-space: nowrap;\r\n            overflow: hidden;\r\n            text-overflow: ellipsis;\r\n        }\r\n\r\n        /* Summary Cards */\r\n        .summary-section {\r\n            margin: 20px 0;\r\n        }\r\n\r\n        .summary-title {\r\n            font-size: 14px;\r\n            font-weight: 600;\r\n            color: #1e293b;\r\n            margin-bottom: 12px;\r\n            padding-left: 8px;\r\n            border-left: 3px solid #dc2626;\r\n        }\r\n\r\n        .summary-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 12px;\r\n        }\r\n\r\n        .summary-card {\r\n            background: white;\r\n            padding: 16px;\r\n            border-radius: 8px;\r\n            border: 1px solid #fecaca;\r\n            text-align: center;\r\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);\r\n        }\r\n\r\n        .summary-number {\r\n            font-size: 20px;\r\n            font-weight: 700;\r\n            color: #dc2626;\r\n            margin-bottom: 6px;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        .summary-label {\r\n            font-size: 10px;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.8px;\r\n            color: #991b1b;\r\n            font-weight: 600;\r\n        }\r\n\r\n        /* Notes Section */\r\n        .notes-section {\r\n            margin: 16px 0;\r\n            padding: 16px;\r\n            background: #fefce8;\r\n            border-radius: 8px;\r\n            border-left: 4px solid #f59e0b;\r\n        }\r\n\r\n        .notes-label {\r\n            font-size: 11px;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.8px;\r\n            color: #92400e;\r\n            margin-bottom: 8px;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .notes-content {\r\n            font-size: 12px;\r\n            color: #854d0e;\r\n            line-height: 1.5;\r\n        }\r\n\r\n        /* Transactions Table */\r\n        .transactions-section {\r\n            margin: 25px 0;\r\n        }\r\n\r\n        .section-title {\r\n            font-size: 14px;\r\n            font-weight: 600;\r\n            color: #1e293b;\r\n            margin-bottom: 12px;\r\n            padding-left: 8px;\r\n            border-left: 3px solid #dc2626;\r\n        }\r\n\r\n        .transactions-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            font-size: 11px;\r\n            table-layout: fixed;\r\n        }\r\n\r\n        .transactions-table thead {\r\n            background: linear-gradient(to right, #dc2626, #ef4444);\r\n        }\r\n\r\n        .transactions-table th {\r\n            padding: 10px 8px;\r\n            text-align: left;\r\n            font-weight: 600;\r\n            color: white;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.5px;\r\n            border: none;\r\n            font-size: 10px;\r\n        }\r\n\r\n        .transactions-table td {\r\n            padding: 9px 8px;\r\n            border-bottom: 1px solid #fecaca;\r\n            vertical-align: middle;\r\n        }\r\n\r\n        .transactions-table tbody tr:nth-child(even) {\r\n            background-color: #fef2f2;\r\n        }\r\n\r\n        /* Column widths - Only Date, Full Name, Currency, Amount Paid, Amount (LC) */\r\n        .col-sn { width: 40px; text-align: center; }\r\n        .col-date { width: 100px; }\r\n        .col-name { width: 220px; }\r\n        .col-currency { width: 100px; }\r\n        .col-amount { width: 130px; text-align: right; }\r\n        .col-amount-lc { width: 140px; text-align: right; }\r\n\r\n        .amount-cell {\r\n            text-align: right;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n            font-weight: 600;\r\n            color: #dc2626;\r\n        }\r\n\r\n        /* Totals Section */\r\n        .totals-section {\r\n            margin: 20px 0;\r\n            background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);\r\n            padding: 20px;\r\n            border-radius: 8px;\r\n            border: 1px solid #fecaca;\r\n        }\r\n\r\n        .totals-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 16px;\r\n        }\r\n\r\n        .total-card {\r\n            background: white;\r\n            padding: 16px;\r\n            border-radius: 8px;\r\n            text-align: center;\r\n            border: 1px solid #fecaca;\r\n        }\r\n\r\n        .total-label {\r\n            font-size: 11px;\r\n            color: #991b1b;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.8px;\r\n            margin-bottom: 8px;\r\n            font-weight: 600;\r\n        }\r\n\r\n        .total-value {\r\n            font-size: 24px;\r\n            font-weight: 700;\r\n            color: #dc2626;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        .grand-total {\r\n            grid-column: span 2;\r\n            background: linear-gradient(to right, #dc2626, #ef4444);\r\n            color: white;\r\n            padding: 20px;\r\n        }\r\n\r\n        .grand-total .total-label {\r\n            color: rgba(255, 255, 255, 0.9);\r\n        }\r\n\r\n        .grand-total .total-value {\r\n            color: white;\r\n            font-size: 28px;\r\n        }\r\n\r\n        /* Footer */\r\n        .footer-section {\r\n            margin-top: 30px;\r\n            padding-top: 20px;\r\n            border-top: 1px solid #fecaca;\r\n            text-align: center;\r\n        }\r\n\r\n        .footer-text {\r\n            color: #475569;\r\n            font-size: 11px;\r\n            line-height: 1.6;\r\n            margin-bottom: 8px;\r\n        }\r\n\r\n        .footer-verse {\r\n            font-style: italic;\r\n            color: #dc2626;\r\n            font-size: 11px;\r\n            font-weight: 500;\r\n        }\r\n\r\n        /* Print Info */\r\n        .print-info {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-size: 10px;\r\n            margin-top: 15px;\r\n            padding-top: 12px;\r\n            border-top: 1px solid #e2e8f0;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n\r\n        /* Utility */\r\n        .text-right { text-align: right; }\r\n        .text-center { text-align: center; }\r\n        .text-mono { font-family: 'SF Mono', 'Monaco', 'Consolas', monospace; }\r\n        \r\n        .no-data {\r\n            text-align: center;\r\n            color: #94a3b8;\r\n            font-style: italic;\r\n            padding: 20px;\r\n            background: #f8fafc;\r\n            border-radius: 8px;\r\n            margin: 10px 0;\r\n        }\r\n\r\n        /* Status Badges */\r\n        .status-badge {\r\n            display: inline-block;\r\n            padding: 3px 8px;\r\n            border-radius: 4px;\r\n            font-size: 9px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.3px;\r\n        }\r\n\r\n        .status-draft {\r\n            background: #fef3c7;\r\n            color: #92400e;\r\n        }\r\n\r\n        .status-submitted {\r\n            background: #d1fae5;\r\n            color: #065f46;\r\n        }\r\n\r\n        .status-cancelled {\r\n            background: #fee2e2;\r\n            color: #991b1b;\r\n        }\r\n\r\n        /* Anonymous Indicator */\r\n        .anonymous-tag {\r\n            display: inline-block;\r\n            background: #f3f4f6;\r\n            color: #6b7280;\r\n            padding: 2px 6px;\r\n            border-radius: 3px;\r\n            font-size: 9px;\r\n            font-weight: 500;\r\n            font-style: italic;\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"report-container\">\r\n        <!-- Header -->\r\n        <div class=\"header-section\">\r\n            <div class=\"report-title\">ANONYMOUS TITHES BATCH REPORT</div>\r\n            <div class=\"report-subtitle\">Anonymous Tithes Collection Summary</div>\r\n            <div class=\"batch-badge\">Batch: {{ doc.name }}</div>\r\n        </div>\r\n\r\n        <!-- Batch Information -->\r\n        <div class=\"batch-info\">\r\n            <div class=\"info-grid\">\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Month</span>\r\n                    <span class=\"info-value\">{{ doc.month or \"\" }}</span>\r\n                </div>\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Branch</span>\r\n                    <span class=\"info-value\">{{ doc.branch or \"\" }}</span>\r\n                </div>\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Reporting Date</span>\r\n                    <span class=\"info-value\">{{ frappe.format(doc.reporting_date, {'fieldtype': 'Date'}) }}</span>\r\n                </div>\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Collection Period</span>\r\n                    <span class=\"info-value\">\r\n                        {{ frappe.format(doc.start_date, {'fieldtype': 'Date'}) }} to {{ frappe.format(doc.end_date, {'fieldtype': 'Date'}) }}\r\n                    </span>\r\n                </div>\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Bank Account</span>\r\n                    <span class=\"info-value\">{{ doc.designated_bank_acct or \"\" }}</span>\r\n                </div>\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Currency</span>\r\n                    <span class=\"info-value\">{{ doc.currency or \"NGN\" }}</span>\r\n                </div>\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Bank GL</span>\r\n                    <span class=\"info-value\">{{ doc.bank_gl or \"Not specified\" }}</span>\r\n                </div>\r\n                <div class=\"info-item\">\r\n                    <span class=\"info-label\">Status</span>\r\n                    <span class=\"info-value\">\r\n                        {% if doc.docstatus == 0 %}\r\n                            <span class=\"status-badge status-draft\">Draft</span>\r\n                        {% elif doc.docstatus == 1 %}\r\n                            <span class=\"status-badge status-submitted\">Submitted</span>\r\n                        {% elif doc.docstatus == 2 %}\r\n                            <span class=\"status-badge status-cancelled\">Cancelled</span>\r\n                        {% endif %}\r\n                    </span>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Summary Statistics -->\r\n        <div class=\"summary-section\">\r\n            <div class=\"summary-title\">Collection Summary</div>\r\n            <div class=\"summary-grid\">\r\n                <div class=\"summary-card\">\r\n                    <div class=\"summary-number\">\r\n                        {{ doc.tithe_transaction_entry_for_anonymous|length if doc.tithe_transaction_entry_for_anonymous else 0 }}\r\n                    </div>\r\n                    <div class=\"summary-label\">Total Transactions</div>\r\n                </div>\r\n                <div class=\"summary-card\">\r\n                    <div class=\"summary-number\">\r\n                        {% if doc.tithe_transaction_entry_for_anonymous and doc.tithe_transaction_entry_for_anonymous|length > 0 %}\r\n                            {% set total_amount = 0 %}\r\n                            {% for row in doc.tithe_transaction_entry_for_anonymous %}\r\n                                {% set total_amount = total_amount + (row.amount_in_lc or row.amount_paid or 0) %}\r\n                            {% endfor %}\r\n                            {{ frappe.utils.fmt_money(total_amount / doc.tithe_transaction_entry_for_anonymous|length, currency=doc.currency or 'NGN') }}\r\n                        {% else %}\r\n                            {{ frappe.utils.fmt_money(0, currency=doc.currency or 'NGN') }}\r\n                        {% endif %}\r\n                    </div>\r\n                    <div class=\"summary-label\">Average Amount</div>\r\n                </div>\r\n                <div class=\"summary-card\">\r\n                    <div class=\"summary-number\">{{ doc.currency or \"NGN\" }}</div>\r\n                    <div class=\"summary-label\">Currency</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Notes Section -->\r\n        {% if doc.description %}\r\n        <div class=\"notes-section\">\r\n            <div class=\"notes-label\">Description / Notes</div>\r\n            <div class=\"notes-content\">{{ doc.description }}</div>\r\n        </div>\r\n        {% endif %}\r\n\r\n        <!-- Anonymous Tithes Transactions -->\r\n        <div class=\"transactions-section\">\r\n            <div class=\"section-title\">Anonymous Tithes Transactions</div>\r\n            \r\n            {% if doc.tithe_transaction_entry_for_anonymous and doc.tithe_transaction_entry_for_anonymous|length > 0 %}\r\n            <table class=\"transactions-table\">\r\n                <thead>\r\n                    <tr>\r\n                        <th class=\"col-sn\">S/N</th>\r\n                        <th class=\"col-date\">Date</th>\r\n                        <th class=\"col-name\">Full Name</th>\r\n                        <th class=\"col-currency\">Currency</th>\r\n                        <th class=\"col-amount\">Amount Paid</th>\r\n                        <th class=\"col-amount-lc\">Amount (LC)</th>\r\n                    </tr>\r\n                </thead>\r\n                <tbody>\r\n                    {% for row in doc.tithe_transaction_entry_for_anonymous %}\r\n                    <tr>\r\n                        <td class=\"text-center\">{{ loop.index }}</td>\r\n                        <td>{{ frappe.format(row.date, {'fieldtype': 'Date'}) if row.date else \"\" }}</td>\r\n                        <td>\r\n                            {% if row.full_name %}\r\n                                {{ row.full_name }}\r\n                            {% else %}\r\n                                <span class=\"anonymous-tag\">Anonymous</span>\r\n                            {% endif %}\r\n                        </td>\r\n                        <td>{{ row.currency or \"NGN\" }}</td>\r\n                        <td class=\"amount-cell\">\r\n                            {{ frappe.utils.fmt_money(row.amount_paid or 0, currency=row.currency or 'NGN') }}\r\n                        </td>\r\n                        <td class=\"amount-cell\">\r\n                            {% set lc_amount = row.amount_in_lc or (row.amount_paid or 0) * (row.exchange_rate or 1) %}\r\n                            {{ frappe.utils.fmt_money(lc_amount, currency=doc.currency or 'NGN') }}\r\n                        </td>\r\n                    </tr>\r\n                    {% endfor %}\r\n                </tbody>\r\n            </table>\r\n            {% else %}\r\n            <div class=\"no-data\">\r\n                No anonymous tithes transactions recorded for this period.\r\n            </div>\r\n            {% endif %}\r\n        </div>\r\n\r\n        <!-- Totals Section -->\r\n        <div class=\"totals-section\">\r\n            <div class=\"totals-grid\">\r\n                <div class=\"total-card\">\r\n                    <div class=\"total-label\">Total Transactions</div>\r\n                    <div class=\"total-value\">\r\n                        {{ doc.tithe_transaction_entry_for_anonymous|length if doc.tithe_transaction_entry_for_anonymous else 0 }}\r\n                    </div>\r\n                </div>\r\n                <div class=\"total-card\">\r\n                    <div class=\"total-label\">Total Amount</div>\r\n                    <div class=\"total-value\">\r\n                        {{ frappe.utils.fmt_money(doc.amount_paid or 0, currency=doc.currency or 'NGN') }}\r\n                    </div>\r\n                </div>\r\n                <div class=\"total-card grand-total\">\r\n                    <div class=\"total-label\">TOTAL ANONYMOUS TITHES COLLECTED</div>\r\n                    <div class=\"total-value\">\r\n                        {{ frappe.utils.fmt_money(doc.amount_paid or 0, currency=doc.currency or 'NGN') }}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Footer -->\r\n        <div class=\"footer-section\">\r\n            <div class=\"footer-text\">\r\n                Anonymous tithes represent generous contributions from members who wish to give anonymously.<br>\r\n                These funds are used for special projects, benevolence, and ministry expansion.\r\n            </div>\r\n            <div class=\"footer-verse\">\r\n                \"But when you give to the needy, do not let your left hand know what your right hand is doing, \r\n                so that your giving may be in secret. Then your Father, who sees what is done in secret, will reward you.\" - Matthew 6:3-4\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Print Info -->\r\n        <div class=\"print-info\">\r\n            Generated by Church Management System \u2022 Printed on: {{ frappe.utils.now_datetime().strftime('%Y-%m-%d %H:%M') }}\r\n        </div>\r\n    </div>\r\n</body>\r\n</html>",
