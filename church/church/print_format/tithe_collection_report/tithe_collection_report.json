 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');\r\n        \r\n        @media print {\r\n            @page {\r\n                margin: 15mm 10mm 15mm 10mm;\r\n                size: A4 portrait;\r\n            }\r\n            \r\n            body { \r\n                margin: 0;\r\n                -webkit-print-color-adjust: exact;\r\n            }\r\n            \r\n            .page-break { \r\n                page-break-after: always;\r\n                break-after: page;\r\n            }\r\n            \r\n            .avoid-break {\r\n                page-break-inside: avoid;\r\n                break-inside: avoid;\r\n            }\r\n        }\r\n        \r\n        body {\r\n            font-family: 'Inter', sans-serif;\r\n            color: #1e293b;\r\n            line-height: 1.4;\r\n            font-size: 12px;\r\n            background: white;\r\n            padding: 0;\r\n            margin: 0;\r\n        }\r\n        \r\n        /* Header Section */\r\n        .header-section {\r\n            text-align: center;\r\n            margin-bottom: 20px;\r\n            padding-bottom: 15px;\r\n            border-bottom: 2px solid #3b82f6;\r\n        }\r\n        \r\n        .report-title {\r\n            color: #1e40af;\r\n            font-size: 24px;\r\n            font-weight: 700;\r\n            margin: 8px 0 5px 0;\r\n            letter-spacing: -0.5px;\r\n        }\r\n        \r\n        .report-subtitle {\r\n            color: #64748b;\r\n            font-size: 13px;\r\n            margin: 5px 0;\r\n            font-weight: 500;\r\n        }\r\n        \r\n        .batch-badge {\r\n            display: inline-block;\r\n            background: #3b82f6;\r\n            color: white;\r\n            padding: 6px 16px;\r\n            border-radius: 4px;\r\n            font-size: 11px;\r\n            font-weight: 600;\r\n            margin-top: 8px;\r\n            letter-spacing: 0.3px;\r\n        }\r\n        \r\n        /* Batch Info Compact */\r\n        .batch-info {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 12px;\r\n            margin-bottom: 20px;\r\n            background: #f8fafc;\r\n            padding: 16px;\r\n            border-radius: 8px;\r\n            border: 1px solid #e2e8f0;\r\n        }\r\n        \r\n        .info-item {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 8px;\r\n            min-width: 0; /* Prevent wrapping */\r\n        }\r\n        \r\n        .info-label {\r\n            color: #64748b;\r\n            font-size: 11px;\r\n            font-weight: 600;\r\n            white-space: nowrap;\r\n        }\r\n        \r\n        .info-value {\r\n            color: #1e293b;\r\n            font-weight: 600;\r\n            font-size: 12px;\r\n            white-space: nowrap;\r\n            overflow: hidden;\r\n            text-overflow: ellipsis;\r\n        }\r\n        \r\n        /* Compact Table */\r\n        .table-container {\r\n            margin: 20px 0;\r\n            overflow: visible;\r\n        }\r\n        \r\n        .transactions-table {\r\n            width: 100%;\r\n            border-collapse: collapse;\r\n            font-size: 11px;\r\n            table-layout: fixed;\r\n        }\r\n        \r\n        .transactions-table thead {\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n        }\r\n        \r\n        .transactions-table th {\r\n            padding: 12px 8px;\r\n            text-align: left;\r\n            font-weight: 600;\r\n            color: white;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.5px;\r\n            border: none;\r\n            font-size: 10px;\r\n        }\r\n        \r\n        .transactions-table td {\r\n            padding: 10px 8px;\r\n            border-bottom: 1px solid #e2e8f0;\r\n            vertical-align: middle;\r\n            line-height: 1.3;\r\n        }\r\n        \r\n        .transactions-table tbody tr:nth-child(even) {\r\n            background-color: #f8fafc;\r\n        }\r\n        \r\n        .transactions-table tbody tr:hover {\r\n            background-color: #f1f5f9;\r\n        }\r\n        \r\n        /* Column widths - optimized for A4 */\r\n        .col-sn { width: 30px; }\r\n        .col-id { width: 80px; }\r\n        .col-name { width: 140px; }\r\n        .col-date { width: 80px; }\r\n        .col-type { width: 70px; }\r\n        .col-currency { width: 70px; }\r\n        .col-amount { width: 85px; }\r\n        .col-worker { width: 85px; }\r\n        .col-member { width: 85px; }\r\n        \r\n        .amount-cell {\r\n            text-align: right;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n            font-weight: 600;\r\n            color: #1e40af;\r\n        }\r\n        \r\n        .type-badge {\r\n            display: inline-block;\r\n            padding: 4px 8px;\r\n            border-radius: 4px;\r\n            font-size: 10px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            white-space: nowrap;\r\n        }\r\n        \r\n        .type-worker {\r\n            background: #10b981;\r\n            color: white;\r\n        }\r\n        \r\n        .type-member {\r\n            background: #3b82f6;\r\n            color: white;\r\n        }\r\n        \r\n        /* Totals Section - Compact */\r\n        .totals-section {\r\n            margin: 20px 0;\r\n            background: #f8fafc;\r\n            padding: 16px;\r\n            border-radius: 8px;\r\n            border: 1px solid #e2e8f0;\r\n        }\r\n        \r\n        .totals-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(4, 1fr);\r\n            gap: 12px;\r\n        }\r\n        \r\n        .total-card {\r\n            background: white;\r\n            padding: 14px;\r\n            border-radius: 6px;\r\n            text-align: center;\r\n            border: 1px solid #e2e8f0;\r\n            min-width: 0; /* Prevent wrapping */\r\n        }\r\n        \r\n        .total-label {\r\n            font-size: 10px;\r\n            color: #64748b;\r\n            margin-bottom: 6px;\r\n            font-weight: 600;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.5px;\r\n            white-space: nowrap;\r\n        }\r\n        \r\n        .total-value {\r\n            font-size: 18px;\r\n            font-weight: 700;\r\n            color: #1e40af;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n            white-space: nowrap;\r\n            overflow: hidden;\r\n            text-overflow: ellipsis;\r\n        }\r\n        \r\n        .grand-total {\r\n            grid-column: span 4;\r\n            background: linear-gradient(to right, #1e40af, #3b82f6);\r\n            color: white;\r\n            padding: 16px;\r\n        }\r\n        \r\n        .grand-total .total-label {\r\n            color: rgba(255, 255, 255, 0.9);\r\n        }\r\n        \r\n        .grand-total .total-value {\r\n            color: white;\r\n            font-size: 22px;\r\n        }\r\n        \r\n        /* Receipt Status Compact */\r\n        .receipt-status {\r\n            margin: 16px 0;\r\n            padding: 14px;\r\n            background: #fff7ed;\r\n            border-radius: 6px;\r\n            border-left: 4px solid #f59e0b;\r\n        }\r\n        \r\n        .status-header {\r\n            font-size: 12px;\r\n            font-weight: 600;\r\n            color: #92400e;\r\n            margin-bottom: 10px;\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 6px;\r\n        }\r\n        \r\n        .status-grid {\r\n            display: grid;\r\n            grid-template-columns: repeat(3, 1fr);\r\n            gap: 10px;\r\n        }\r\n        \r\n        .status-item {\r\n            background: white;\r\n            padding: 10px;\r\n            border-radius: 4px;\r\n            text-align: center;\r\n            border: 1px solid #fed7aa;\r\n        }\r\n        \r\n        .status-value {\r\n            font-size: 16px;\r\n            font-weight: 700;\r\n            color: #1e293b;\r\n        }\r\n        \r\n        .status-label {\r\n            font-size: 10px;\r\n            color: #64748b;\r\n            margin-top: 2px;\r\n        }\r\n        \r\n        /* Footer Compact */\r\n        .footer-section {\r\n            margin-top: 25px;\r\n            padding-top: 20px;\r\n            border-top: 1px solid #e2e8f0;\r\n        }\r\n        \r\n        .signature-area {\r\n            display: grid;\r\n            grid-template-columns: repeat(2, 1fr);\r\n            gap: 40px;\r\n            margin-bottom: 15px;\r\n        }\r\n        \r\n        .signature-box {\r\n            text-align: center;\r\n        }\r\n        \r\n        .signature-line {\r\n            border-top: 1px solid #94a3b8;\r\n            padding-top: 35px;\r\n            position: relative;\r\n        }\r\n        \r\n        .signature-label {\r\n            position: absolute;\r\n            top: 10px;\r\n            left: 0;\r\n            right: 0;\r\n            font-size: 11px;\r\n            color: #64748b;\r\n            font-weight: 500;\r\n        }\r\n        \r\n        .print-info {\r\n            text-align: center;\r\n            color: #64748b;\r\n            font-size: 11px;\r\n        }\r\n        \r\n        .print-date {\r\n            background: #f1f5f9;\r\n            display: inline-block;\r\n            padding: 6px 12px;\r\n            border-radius: 4px;\r\n            margin-top: 8px;\r\n            font-family: 'SF Mono', 'Monaco', 'Consolas', monospace;\r\n        }\r\n        \r\n        /* Utility Classes */\r\n        .text-right { text-align: right; }\r\n        .text-center { text-align: center; }\r\n        .text-bold { font-weight: 700; }\r\n        .text-mono { font-family: 'SF Mono', 'Monaco', 'Consolas', monospace; }\r\n        \r\n        .no-print { display: none; }\r\n        \r\n        @media print {\r\n            .no-print { display: none !important; }\r\n            \r\n            .transactions-table {\r\n                font-size: 10px;\r\n            }\r\n            \r\n            .transactions-table th,\r\n            .transactions-table td {\r\n                padding: 8px 6px;\r\n            }\r\n            \r\n            /* Force table to fit within page width */\r\n            .transactions-table {\r\n                width: 100%;\r\n                max-width: 100%;\r\n            }\r\n        }\r\n    </style>\r\n</head>\r\n<body>\r\n    <!-- Header -->\r\n    <div class=\"header-section\">\r\n        <div class=\"report-title\">TITHE COLLECTION REPORT</div>\r\n        <div class=\"report-subtitle\">{{ doc.month }} \u2022 {{ doc.branch }}</div>\r\n        <div class=\"batch-badge\">Batch: {{ doc.name }}</div>\r\n    </div>\r\n    \r\n    <!-- Batch Information - Compact -->\r\n    <div class=\"batch-info\">\r\n        <div class=\"info-item\">\r\n            <span class=\"info-label\">Period:</span>\r\n            <span class=\"info-value\">{{ frappe.format(doc.start_date, {'fieldtype': 'Date'}) }} - {{ frappe.format(doc.end_date, {'fieldtype': 'Date'}) }}</span>\r\n        </div>\r\n        <div class=\"info-item\">\r\n            <span class=\"info-label\">Report Date:</span>\r\n            <span class=\"info-value\">{{ frappe.format(doc.reporting_date, {'fieldtype': 'Date'}) }}</span>\r\n        </div>\r\n        <div class=\"info-item\">\r\n            <span class=\"info-label\">Bank Account:</span>\r\n            <span class=\"info-value\">{{ doc.designated_bank_acct }}</span>\r\n        </div>\r\n        <div class=\"info-item\">\r\n            <span class=\"info-label\">Currency:</span>\r\n            <span class=\"info-value\">{{ doc.currency }}</span>\r\n        </div>\r\n        <div class=\"info-item\">\r\n            <span class=\"info-label\">Total Txns:</span>\r\n            <span class=\"info-value\">{{ doc.total_transactions }}</span>\r\n        </div>\r\n        <div class=\"info-item\">\r\n            <span class=\"info-label\">Status:</span>\r\n            <span class=\"info-value\">\r\n                {% if doc.docstatus == 0 %}Draft{% elif doc.docstatus == 1 %}Submitted{% else %}Cancelled{% endif %}\r\n            </span>\r\n        </div>\r\n    </div>\r\n    \r\n    <!-- Transactions Table -->\r\n    <div class=\"table-container\">\r\n        <table class=\"transactions-table\">\r\n            <thead>\r\n                <tr>\r\n                    <th class=\"col-sn\">#</th>\r\n                    <th class=\"col-id\">Member ID</th>\r\n                    <th class=\"col-name\">Full Name</th>\r\n                    <th class=\"col-date\">Date</th>\r\n                    <th class=\"col-type\">Source</th>\r\n                    <th class=\"col-currency\">Currency</th>\r\n                    <th class=\"col-amount text-right\">Amount</th>\r\n                    <th class=\"col-worker text-right\">Worker Tithe</th>\r\n                    <th class=\"col-member text-right\">Member Tithe</th>\r\n                </tr>\r\n            </thead>\r\n            <tbody>\r\n                {% for row in doc.tithe_transaction_entry %}\r\n                <tr>\r\n                    <td>{{ loop.index }}</td>\r\n                    <td>{{ row.member_id }}</td>\r\n                    <td>{{ row.full_name }}</td>\r\n                    <td>{{ frappe.format(row.date, {'fieldtype': 'Date'}) }}</td>\r\n                    <td>\r\n                        <span class=\"type-badge {{ 'type-worker' if row.type == 'Worker' else 'type-member' }}\">\r\n                            {{ row.type }}\r\n                        </span>\r\n                    </td>\r\n                    <td>{{ row.currency }}</td>\r\n                    <td class=\"amount-cell\">{{ frappe.format(row.amount_paid, {'fieldtype': 'Currency'}) }}</td>\r\n                    <td class=\"amount-cell\">{{ frappe.format(row.worker_tithe, {'fieldtype': 'Currency'}) }}</td>\r\n                    <td class=\"amount-cell\">{{ frappe.format(row.member_tithe, {'fieldtype': 'Currency'}) }}</td>\r\n                </tr>\r\n                {% endfor %}\r\n            </tbody>\r\n        </table>\r\n    </div>\r\n    \r\n    <!-- Totals Section -->\r\n    <div class=\"totals-section\">\r\n        <div class=\"totals-grid\">\r\n            <div class=\"total-card\">\r\n                <div class=\"total-label\">Transactions</div>\r\n                <div class=\"total-value\">{{ doc.total_transactions }}</div>\r\n            </div>\r\n            <div class=\"total-card\">\r\n                <div class=\"total-label\">Worker Tithe</div>\r\n                <div class=\"total-value\">{{ frappe.format(doc.total_for_workers, {'fieldtype': 'Currency', 'currency': doc.currency}) }}</div>\r\n            </div>\r\n            <div class=\"total-card\">\r\n                <div class=\"total-label\">Member Tithe</div>\r\n                <div class=\"total-value\">{{ frappe.format(doc.total_for_members, {'fieldtype': 'Currency', 'currency': doc.currency}) }}</div>\r\n            </div>\r\n            <div class=\"total-card\">\r\n                <div class=\"total-label\">Currency</div>\r\n                <div class=\"total-value\">{{ doc.currency }}</div>\r\n            </div>\r\n            <div class=\"total-card grand-total\">\r\n                <div class=\"total-label\">GRAND TOTAL</div>\r\n                <div class=\"total-value\">{{ frappe.format(doc.amount_paid, {'fieldtype': 'Currency', 'currency': doc.currency}) }}</div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    \r\n    <!-- Receipt Status -->\r\n    {% if doc.docstatus == 1 and doc.receipt_status %}\r\n    <div class=\"receipt-status\">\r\n        <div class=\"status-header\">\r\n            <span>\ud83d\udcdd Receipt Generation Status: {{ doc.receipt_status }}</span>\r\n        </div>\r\n        <div class=\"status-grid\">\r\n            <div class=\"status-item\">\r\n                <div class=\"status-value\">{{ doc.receipts_created }}</div>\r\n                <div class=\"status-label\">Created</div>\r\n            </div>\r\n            <div class=\"status-item\">\r\n                <div class=\"status-value\">{{ doc.total_transactions }}</div>\r\n                <div class=\"status-label\">Total</div>\r\n            </div>\r\n            {% if doc.receipts_failed > 0 %}\r\n            <div class=\"status-item\" style=\"background: #fee2e2; border-color: #fecaca;\">\r\n                <div class=\"status-value\" style=\"color: #dc2626;\">{{ doc.receipts_failed }}</div>\r\n                <div class=\"status-label\" style=\"color: #dc2626;\">Failed</div>\r\n            </div>\r\n            {% endif %}\r\n        </div>\r\n    </div>\r\n    {% endif %}\r\n    \r\n    <!-- Footer -->\r\n    <div class=\"footer-section\">\r\n        <div class=\"signature-area\">\r\n            <div class=\"signature-box\">\r\n                <div class=\"signature-line\">\r\n                    <div class=\"signature-label\">Prepared By</div>\r\n                </div>\r\n            </div>\r\n            <div class=\"signature-box\">\r\n                <div class=\"signature-line\">\r\n                    <div class=\"signature-label\">Approved By</div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class=\"print-info\">\r\n            <div>Generated by Church Management System</div>\r\n            <div class=\"print-date\">Printed: {{ frappe.utils.now_datetime().strftime('%Y-%m-%d %H:%M') }}</div>\r\n        </div>\r\n    </div>\r\n    \r\n    <!-- Print optimization script -->\r\n    <script>\r\n        // Ensure table fits on page\r\n        window.addEventListener('load', function() {\r\n            const table = document.querySelector('.transactions-table');\r\n            if (table) {\r\n                // Calculate total width\r\n                let totalWidth = 0;\r\n                table.querySelectorAll('th').forEach(th => {\r\n                    totalWidth += th.offsetWidth;\r\n                });\r\n                \r\n                // If table is too wide, adjust font size\r\n                const pageWidth = 794; // A4 width in pixels at 96dpi\r\n                if (totalWidth > pageWidth * 0.95) {\r\n                    table.style.fontSize = '9.5px';\r\n                    table.querySelectorAll('th, td').forEach(cell => {\r\n                        cell.style.padding = '6px 4px';\r\n                    });\r\n                }\r\n            }\r\n        });\r\n    </script>\r\n</body>\r\n</html>",
